{
  "name": "@bounded-systems/scout-wire",
  "version": "0.1.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "exports": "./mod.ts",
  "imports": {
    "zod": "npm:zod@^4.4.3",
    "verbspec": "jsr:@bounded-systems/verbspec@^0.3.1"
  },
  "tasks": {
    "check": "deno check mod.ts gen.ts",
    "gen": "deno run --allow-read --allow-write gen.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "fmt": { "include": ["*.ts"] },
  "lint": { "include": ["*.ts"] },
  "publish": { "include": ["mod.ts", "manifest.json", "gen.ts", "LICENSE", "README.md"] }
}
